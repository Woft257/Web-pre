# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Server-only Supabase key
SUPABASE_SERVICE_ROLE_KEY=

# Required on Vercel. JWT signing secret for the persistent httpOnly session.
# Use at least 32 random bytes in Production and a different value in Preview.
SESSION_SECRET=

# Required on Vercel. Protects the unlinked /admin operations page.
# Use at least 12 random characters and rotate it after the event.
ADMIN_SECRET=

NEXT_PUBLIC_APP_TIME_ZONE=Asia/Bangkok
