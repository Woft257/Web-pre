# Public Supabase connection (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key
SUPABASE_SERVICE_ROLE_KEY=

# Signed UID session cookie. Use at least 32 random bytes in production.
SESSION_SECRET=

# Admin access for settlement and emergency market controls.
ADMIN_SECRET=

# Live feed: Kalshi prices plus FIFA score. No provider API key is required.
ODDS_PROVIDER=kalshi-fifa
LIVE_FEED_POLL_INTERVAL_MS=2000
ODDS_WORKER_SECRET=

# Public app configuration
NEXT_PUBLIC_APP_TIME_ZONE=Asia/Bangkok
NEXT_PUBLIC_INITIAL_POINTS=10000
