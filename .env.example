# Public Supabase connection (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key
SUPABASE_SERVICE_ROLE_KEY=

# Required on Vercel (Production and Preview). JWT signing secret for the
# persistent httpOnly user cookie. Use at least 32 random bytes in production.
SESSION_SECRET=

# Required on Vercel (Production and Preview). Admin access for settlement and
# emergency market controls. Use at least 12 characters.
ADMIN_SECRET=

# Live feed: Kalshi prices plus FIFA score. No provider API key is required.
ODDS_PROVIDER=kalshi-fifa
LIVE_FEED_POLL_INTERVAL_MS=2000
# Required on Vercel and on any process calling the protected provider webhook.
# Use at least 12 random characters.
ODDS_WORKER_SECRET=

# Public app configuration
NEXT_PUBLIC_APP_TIME_ZONE=Asia/Bangkok
